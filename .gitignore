# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Memory system runtime data
qdrant_data/
memories.json
activity.jsonl
session-summaries/
.last-health-check
archives/

# Project context (local config, not distributed — use .tpl.yaml as template)
project-context.yaml

# IDE — personnels uniquement (.vscode/ intentionnellement suivi pour le kit)
