.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Virtual environments
venv/
.venv/
env/

# Secrets (never commit)
*.key
*.pem
*.env.local
.env
secrets.yaml
secrets.yml
*.secret
**/secrets/

# Dev / CI artifacts
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.pytest_cache/
.ruff_cache/
site/

