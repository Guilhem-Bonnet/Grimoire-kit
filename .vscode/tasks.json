{
  // ════════════════════════════════════════════════════════════════════
  // Grimoire Custom Kit — VS Code Tasks
  // Accès : Ctrl+Shift+P → "Tasks: Run Task"
  // ════════════════════════════════════════════════════════════════════
  "version": "2.0.0",
  "tasks": [

    // ── Groupe : Grimoire Diagnostics ─────────────────────────────────────
    {
      "label": "Grimoire: Doctor",
      "type": "shell",
      "command": "bash grimoire-init.sh doctor",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Doctor --fix",
      "type": "shell",
      "command": "bash grimoire-init.sh doctor --fix",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Validate DNA (tous les archetypes)",
      "type": "shell",
      "command": "bash grimoire-init.sh validate --all",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Validate DNA (fichier courant)",
      "type": "shell",
      "command": "bash grimoire-init.sh validate --dna ${relativeFile}",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },

    // ── Groupe : Grimoire Setup ───────────────────────────────────────────
    {
      "label": "Grimoire: Install hooks",
      "type": "shell",
      "command": "bash grimoire-init.sh hooks --install",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Hooks status",
      "type": "shell",
      "command": "bash grimoire-init.sh hooks --status",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Install archetype",
      "type": "shell",
      "command": "bash grimoire-init.sh install --archetype ${input:archetypeId}",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },

    // ── Groupe : Grimoire Session ─────────────────────────────────────────
    {
      "label": "Grimoire: Nouvelle session-branch",
      "type": "shell",
      "command": "bash grimoire-init.sh session-branch --name ${input:sessionName}",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Resume checkpoint",
      "type": "shell",
      "command": "bash grimoire-init.sh resume --checkpoint ${input:checkpointId}",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // ── Groupe : Grimoire Audit ───────────────────────────────────────────
    {
      "label": "Grimoire: Trace (50 dernières entrées)",
      "type": "shell",
      "command": "bash grimoire-init.sh trace --tail 50",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Changelog",
      "type": "shell",
      "command": "bash grimoire-init.sh changelog",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },

    // ── Groupe : Benchmark ────────────────────────────────────────────
    {
      "label": "Grimoire: Bench summary",
      "type": "shell",
      "command": "bash grimoire-init.sh bench --summary",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Bench report complet",
      "type": "shell",
      "command": "bash grimoire-init.sh bench --report",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Bench --improve (génère bench-context.md pour Sentinel)",
      "type": "shell",
      "command": "bash grimoire-init.sh bench --improve",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },

    // ── Groupe : Gen Tests ────────────────────────────────────────────
    {
      "label": "Grimoire: Gen tests (archetype courant)",
      "type": "shell",
      "command": "python3 framework/tools/gen-tests.py --dna ${input:dnaFile} --out tests/",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },

    // ── Groupe : Context Budget Guard (BM-55) ───────────────────────────
    {
      "label": "Grimoire: Guard — budget contexte (tous agents)",
      "type": "shell",
      "command": "bash grimoire-init.sh guard --suggest",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Guard — agent spécifique",
      "type": "shell",
      "command": "bash grimoire-init.sh guard --agent '${input:agentId}' --detail",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },

    // ── Groupe : DNA Evolution Engine (BM-56) ────────────────────────────
    {
      "label": "Grimoire: Evolve — proposer des évolutions DNA",
      "type": "shell",
      "command": "bash grimoire-init.sh evolve",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Evolve — rapport seul (sans patch)",
      "type": "shell",
      "command": "bash grimoire-init.sh evolve --report",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Evolve — appliquer le dernier patch DNA",
      "type": "shell",
      "command": "bash grimoire-init.sh evolve --apply",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // ── Groupe : Agent Forge (BM-52) ────────────────────────────────
    {
      "label": "Grimoire: Forge agent (depuis description)",
      "type": "shell",
      "command": "bash grimoire-init.sh forge --from '${input:agentDescription}'",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Forge --from-gap (inter-agents)",
      "type": "shell",
      "command": "bash grimoire-init.sh forge --from-gap",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Forge --from-trace (failures sans agent)",
      "type": "shell",
      "command": "bash grimoire-init.sh forge --from-trace",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Grimoire: Forge --list proposals",
      "type": "shell",
      "command": "bash grimoire-init.sh forge --list",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // ── Groupe : Validation grimoire-init.sh ─────────────────────────────
    {
      "label": "Grimoire: Vérification syntaxe bash",
      "type": "shell",
      "command": "bash -n grimoire-init.sh && echo '✅ OK'",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [
        {
          "pattern": {
            "regexp": "grimoire-init\\.sh: line (\\d+): (.*)",
            "file": 0,
            "line": 1,
            "message": 2
          }
        }
      ]
    }
  ],

  "inputs": [
    {
      "id": "archetypeId",
      "type": "promptString",
      "description": "ID de l'archétype (ex: web-app, infra-ops, stack/go)",
      "default": "minimal"
    },
    {
      "id": "sessionName",
      "type": "promptString",
      "description": "Nom de la session Grimoire (ex: feature-auth, bug-fix-login)",
      "default": "feature-dev"
    },
    {
      "id": "checkpointId",
      "type": "promptString",
      "description": "ID court du checkpoint (8 premiers chars)",
      "default": ""
    },
    {
      "id": "dnaFile",
      "type": "promptString",
      "description": "Chemin vers le fichier .dna.yaml",
      "default": "archetypes/web-app/archetype.dna.yaml"
    },
    {
      "id": "agentDescription",
      "type": "promptString",
      "description": "Décris le besoin de l'agent en langage naturel",
      "default": "je veux un agent pour gérer les migrations de base de données"
    },
    {
      "id": "agentId",
      "type": "promptString",
      "description": "ID ou nom de l'agent à analyser (ex: atlas, dev, sentinel)",
      "default": "atlas"
    }
  ]
}
