{
  "manifestVersion": 1,
  "id": "langgraph",
  "name": "LangGraph Bridge",
  "version": "0.1.0",
  "description": "Pont LangGraph : graphes d'agents à état persistant exposés comme workflows Grimoire gouvernés — état explicite, reprises auditées, checkpoints tracés. Matérialise ORC-09 (Workflow State Engine) et ORC-10 (Flow DSL minimal).",
  "license": "MIT",
  "authors": [
    { "name": "Guilhem Bonnet", "url": "https://github.com/Guilhem-Bonnet" }
  ],
  "upstream": {
    "repository": "https://github.com/langchain-ai/langgraph",
    "kind": "framework",
    "pinnedVersion": "0.2.x"
  },
  "compat": {
    "kit": ">=3.11",
    "manifest": 1
  },
  "provides": {
    "agents": ["artifacts/agents/langgraph-graph-runner.agent.md"],
    "skills": ["artifacts/skills/langgraph-graph-design/SKILL.md"],
    "hooks": [],
    "workflows": ["artifacts/prompts/langgraph-import-graph.prompt.md"],
    "instructions": [],
    "nodes": [
      {
        "id": "langgraph-graph",
        "label": "LangGraph StateGraph",
        "description": "Un graphe LangGraph complet (state, nodes, edges conditionnels, checkpoints) exposé comme node composite.",
        "patterns": ["ORC-09", "ORC-10"],
        "pins": [
          { "id": "mission", "direction": "in", "contract": "task-envelope" },
          { "id": "result", "direction": "out", "contract": "handoff-packet" }
        ],
        "compilesTo": ["agent", "workflow"]
      }
    ]
  },
  "patterns": {
    "implements": ["ORC-09", "ORC-10"],
    "requires": ["GOV-01"]
  },
  "permissions": {
    "filesystem": "artifacts",
    "network": true,
    "hooks": [],
    "memory": "none"
  },
  "install": {
    "steps": [
      { "kind": "pip", "packages": ["langgraph"] },
      {
        "kind": "copy",
        "from": "artifacts/agents/langgraph-graph-runner.agent.md",
        "to": ".github/agents/langgraph-graph-runner.agent.md"
      },
      {
        "kind": "copy",
        "from": "artifacts/prompts/langgraph-import-graph.prompt.md",
        "to": ".github/prompts/langgraph-import-graph.prompt.md"
      },
      {
        "kind": "copy",
        "from": "artifacts/skills/langgraph-graph-design",
        "to": ".github/skills/langgraph-graph-design"
      }
    ],
    "verify": "scripts/verify-install.sh"
  }
}
