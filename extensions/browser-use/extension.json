{
  "manifestVersion": 1,
  "id": "browser-use",
  "name": "Browser Use",
  "version": "0.1.0",
  "description": "Agents de navigation web gouvernés : chaque action UI produit une preuve (screenshot, DOM, URL), périmètre de navigation borné par allowlist, actions irréversibles simulées avant exécution.",
  "license": "MIT",
  "authors": [
    { "name": "Guilhem Bonnet", "url": "https://github.com/Guilhem-Bonnet" }
  ],
  "upstream": {
    "repository": "https://github.com/browser-use/browser-use",
    "kind": "tooling",
    "pinnedVersion": "0.3.x"
  },
  "compat": { "kit": ">=3.11", "manifest": 1 },
  "provides": {
    "agents": ["artifacts/agents/browser-use-runner.agent.md"],
    "skills": [],
    "hooks": [],
    "workflows": [],
    "instructions": ["artifacts/instructions/browser-evidence.instructions.md"],
    "nodes": [
      {
        "id": "browser-task",
        "label": "Browser Task",
        "description": "Une tâche de navigation web bornée avec contrat de preuve UI.",
        "patterns": ["QUA-11", "GOV-07"],
        "pins": [
          { "id": "mission", "direction": "in", "contract": "task-envelope" },
          { "id": "result", "direction": "out", "contract": "handoff-packet" }
        ],
        "compilesTo": ["agent"]
      }
    ]
  },
  "patterns": {
    "implements": ["QUA-11", "GOV-07"],
    "requires": ["GOV-02"]
  },
  "permissions": {
    "filesystem": "artifacts",
    "network": true,
    "hooks": [],
    "memory": "none"
  },
  "install": {
    "steps": [
      { "kind": "pip", "packages": ["browser-use"] },
      {
        "kind": "copy",
        "from": "artifacts/agents/browser-use-runner.agent.md",
        "to": ".github/agents/browser-use-runner.agent.md"
      },
      {
        "kind": "copy",
        "from": "artifacts/instructions/browser-evidence.instructions.md",
        "to": ".github/instructions/browser-evidence.instructions.md"
      }
    ],
    "verify": "scripts/verify-install.sh"
  }
}
